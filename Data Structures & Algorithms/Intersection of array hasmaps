class Solution {
  public:
    int intersectSize(vector<int> &a, vector<int> &b) {
        // code  here
        int count = 0;
        
        unordered_map<int,int> mpp;
        
        for(auto newNumber : a){
            mpp[newNumber]++;
        }
        for(auto y : b ){
            mpp[y]++;
            if(mpp[y] == 2 ){
                count++;
            }
        }
        return count;
    }
};
