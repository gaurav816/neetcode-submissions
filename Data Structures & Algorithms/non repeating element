class Solution {
  public:
    int firstNonRepeating(vector<int>& arr) {
        unordered_map<int, int> mpp;

        for (auto nums : arr) {
            mpp[nums]++;
        }

        for (int i = 0; i < arr.size(); i++) {
           int key = arr[i];
           auto found = mpp.find(key);
           if(found->second == 1){
               return found->first;
           }
        }

        return 0;  // convention: -1 when not found
    }
};
